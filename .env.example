# Configurações do Servidor
PORT=3000
NODE_ENV=development

# Microserviço de render Jasper (Spring printServiceCarbon)
PRINT_SERVICE_URL=http://localhost:8080

# Configurações de CORS
# Em desenvolvimento, use * para permitir todos
# Em produção, especifique o domínio do frontend (ex: https://seu-dominio.com)
CORS_ORIGIN=*

# Configurações do Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=maestro
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# JWT Secret (gere uma chave aleatória segura)
JWT_SECRET=sua_chave_secreta_super_segura_aqui
JWT_EXPIRES_IN=7d

# Jira API
JIRA_URL=https://sua-empresa.atlassian.net
JIRA_EMAIL=seu-email@empresa.com
JIRA_API_TOKEN=seu-token-aqui
# Projeto do card-mãe que consolida OS/PD (opcional). Vazio = busca global por cf[10256].
JIRA_PROJECT=

# Relatório Carbon (scraping de core.carbon.cars + cron a cada 15 min)
CARBON_URL=https://core.carbon.cars/
CARBON_USER=seu.usuario
CARBON_PASS=sua_senha_aqui
# Timeout (ms) para o "Atualizar Todos" / overlay sumir
CARBON_PROCESS_TIMEOUT_MS=240000
# Expressão do cron (default a cada 15 min) e execução inicial ao subir
CARBON_CRON_EXPR=*/15 * * * *
CARBON_RUN_ON_BOOT=false

# Conversao DOCX -> PDF (LibreOffice)
# Windows exemplo: C:\\Program Files\\LibreOffice\\program\\soffice.exe
LIBREOFFICE_PATH=

# Diretório base dos PDFs
PDF_BASE_PATH=C:\\OPs

# PDFs de rastreabilidade/IIS gerados na criação (ficam disponíveis p/ download no registro)
RASTREABILIDADE_PDF_DIR=/opt/applicationStorage/orquestra/rastreabilidades

# Etiquetagem (ZPL) — pasta no servidor com os arquivos .txt das OS (CNC/ISO).
# É a MESMA pasta onde a geração de OS grava os TXT já processados (XXXXX→nº OS)
# e de onde a tela de Etiquetagem lê os itens para imprimir/pré-visualizar.
LABELS_DIR=/opt/applicationStorage/orquestra/etiquetas

# Impressão de etiquetas (opcional; a tela também configura por dispositivo).
# Modo padrão quando a tela não especifica: 'network' (Zebra com IP próprio) ou
# 'windows' (impressora compartilhada do Windows). Se LABEL_PRINTER_NAME estiver
# definida e LABEL_PRINTER_MODE vazio, assume 'windows'.
LABEL_PRINTER_MODE=
#
# Modo 'network' — Zebra com IP na rede (TCP raw 9100). Precisa ser alcançável
# a partir do servidor que roda a API (a nuvem NÃO vê impressora de LAN).
LABEL_PRINTER_HOST=
LABEL_PRINTER_PORT=9100
#
# Modo 'windows' — impressora USB/local COMPARTILHADA no Windows. O backend faz
# `copy /B etiqueta.zpl \\host\compartilhamento`. Só funciona com a API rodando
# no Windows que enxerga o compartilhamento. Informe o NOME DE COMPARTILHAMENTO
# (aba Compartilhamento das Propriedades da impressora), ex.: ZEBRA_RAW1.
LABEL_PRINTER_NAME=
# Host do compartilhamento (padrão localhost; nome da máquina para share remoto).
LABEL_PRINTER_HOST_WIN=localhost
